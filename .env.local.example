# Copy this to .env.local and fill in your values
# Never commit .env.local to git

# Supabase — get from supabase.com → project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lemon Squeezy — get from app.lemonsqueezy.com → settings → API
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=

# Resend — get from resend.com → API keys
RESEND_API_KEY=

# Cal.com — your public booking link (e.g. cal.com/nidhi/consult)
NEXT_PUBLIC_CAL_LINK=

# Substack — your newsletter URL
NEXT_PUBLIC_SUBSTACK_URL=
